# Copy to .env.local or .env and fill in a real API key with model access.
OPENAI_API_KEY=

# Use smaller/cheaper models by default for routine work.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PLANNER_MODEL=gpt-4.1-mini
OPENAI_STUDIO_MODEL=gpt-4.1-mini

# Preferred: Gemini. When GEMINI_API_KEY is set, the planner and studio use
# Gemini instead of OpenAI. Free key: https://aistudio.google.com/app/apikey
# (starts with AIza). OpenAI stays as an automatic fallback if Gemini is unset.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional
# FREECAD_CMD=C:\Program Files\FreeCAD 1.1\bin\freecadcmd.exe
